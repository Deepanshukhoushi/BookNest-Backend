# Database Configuration
AUTH_DB_URL=jdbc:mysql://localhost:3306/booknest_auth?createDatabaseIfNotExist=true&useSSL=false
AUTH_DB_USERNAME=root
AUTH_DB_PASSWORD=your_password

# JPA Configuration
AUTH_JPA_DDL_AUTO=update
AUTH_JPA_SHOW_SQL=true

# Security Configuration
AUTH_JWT_SECRET=your_jwt_secret_key_at_least_32_characters_long
AUTH_JWT_EXPIRATION=3600000

# Google OAuth2 Configuration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth2 Configuration
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Service Ports
AUTH_PORT=8082
BOOK_PORT=8081
CART_PORT=8083
ORDER_PORT=8084
WALLET_PORT=8085
REVIEW_PORT=8086
NOTIFICATION_PORT=8087
WISHLIST_PORT=8089
WEBSITE_PORT=8080

# Service URLs (Internal)
BOOK_SERVICE_URL=http://localhost:8081
CART_SERVICE_URL=http://localhost:8083
ORDER_SERVICE_URL=http://localhost:8084

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Order Database Configuration
ORDER_DB_URL=jdbc:mysql://localhost:3306/booknest_order?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
ORDER_DB_USERNAME=root
ORDER_DB_PASSWORD=

