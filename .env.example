# Notification Database Configuration
NOTIF_DB_URL=jdbc:mysql://localhost:3306/booknest_notification?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
NOTIF_DB_USERNAME=root
